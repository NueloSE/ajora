# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stellar — funded testnet keypair for the agent to sign transactions
# Generate one at: https://laboratory.stellar.org/#account-creator?network=test
AGENT_SECRET_KEY=

# Stellar network config
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=Test SDF Network ; September 2015

# Soroban contract addresses (filled in by scripts/deploy.sh after deployment)
ROTATING_SAVINGS_CONTRACT_ID=
TARGET_SAVINGS_CONTRACT_ID=
ZK_VERIFIER_CONTRACT_ID=
REPUTATION_CONTRACT_ID=

# Telegram bot notifications
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Add the bot to a group chat (or start a personal chat with it)
# 3. Send any message in the chat, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Look for "chat":{"id": ...} — that number is your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Agent polling config
POLL_INTERVAL_MS=60000    # how often to check groups in milliseconds (60s default)
USE_MOCK_DATA=true        # set to false to read live from Stellar testnet
